{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:admin": "astro build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:admin && npm run build:server",
    "dev": "npm run build:admin && tsx watch server/index.ts",
    "start": "node ./dist/index.js"
  },
  "dependencies": {
    "astro": "^6",
    "cookie": "^1",
    "express": "^4.21",
    "express-rate-limit": "^7",
    "gray-matter": "^4",
    "helmet": "^8",
    "multer": "^2",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/express": "^4",
    "@types/multer": "^1",
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5"
  }
}
