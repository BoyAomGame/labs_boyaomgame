---
import BlogLayout from '../layouts/BlogLayout.astro';
import Tag from '../components/Tag.astro';
import { getPost, coverUrl } from '../lib/posts.js';
import { renderMarkdown } from '../lib/markdown.js';

const { slug } = Astro.params as { slug: string };

const result = getPost(slug);

if (!result) {
  return new Response(null, { status: 404, statusText: 'Post not found' });
}

const { meta, body } = result;
const html = renderMarkdown(body, meta.slug);

const base = import.meta.env.BASE_URL;
const formattedDate = new Date(meta.date + 'T00:00:00Z').toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---
<BlogLayout title={meta.title} description={`${meta.title} — boyaomgame labs blog`}>
  <div class="page-wrapper">
    <div class="post-page">
      <a class="post-page__back" href={base}>&#8592; all posts</a>

      {meta.cover && (
        <img
          class="post-page__cover"
          src={coverUrl(meta.slug, meta.cover)}
          alt={`Cover image for ${meta.title}`}
        />
      )}

      <header class="post-page__header">
        <h1 class="post-page__title">{meta.title}</h1>
        <div class="post-page__meta">
          <time class="post-page__date" datetime={meta.date}>{formattedDate}</time>
          {meta.tags && meta.tags.length > 0 && (
            <div class="post-page__tags">
              {meta.tags.map((t) => <Tag name={t} />)}
            </div>
          )}
        </div>
      </header>

      <article class="prose" set:html={html} />
    </div>
  </div>
</BlogLayout>
