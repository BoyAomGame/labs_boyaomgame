---
import Tag from './Tag.astro';
import { coverUrl } from '../lib/posts.js';

interface Props {
  title: string;
  date: string;
  slug: string;
  cover?: string;
  tags?: string[];
}

const { title, date, slug, cover, tags } = Astro.props;
const base = import.meta.env.BASE_URL;
const postUrl = `${base}/${slug}`;
const formattedDate = new Date(date + 'T00:00:00Z').toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---
<article class="post-card">
  {cover && (
    <img
      class="post-card__cover"
      src={coverUrl(slug, cover)}
      alt={`Cover image for ${title}`}
      loading="lazy"
    />
  )}
  <div class="post-card__body">
    <h2 class="post-card__title">
      <a href={postUrl}>{title}</a>
    </h2>
    <time class="post-card__date" datetime={date}>{formattedDate}</time>
    {tags && tags.length > 0 && (
      <div class="post-card__tags">
        {tags.map((t) => <Tag name={t} />)}
      </div>
    )}
  </div>
</article>
