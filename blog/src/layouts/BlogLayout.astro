---
import '../styles/blog.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Blog', description = 'boyaomgame labs blog' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — labs.boyaomgame.xyz</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-header__logo" href={base}>labs<span>.</span>blog</a>
        <nav>
          <a href="/">hub</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      &copy; {new Date().getFullYear()} boyaomgame labs
    </footer>
  </body>
</html>
