# ---------------------------------------------------------------------------
# labs_boyaomgame — environment template
# Copy the values you need into per-app .env files (e.g. backend/.env) or
# inject them via PM2 (see ecosystem.config.cjs). NEVER commit real secrets.
# ---------------------------------------------------------------------------

# Shared: path to the runtime data volume.
# Dev default (if unset) = <repo-root>/misc/data
# Prod: an absolute path to a mounted volume, e.g. /srv/labs/data
DATA_DIR=./misc/data

# Per-app network binding. PM2 sets these per process (see ecosystem.config.cjs).
# hub=4321  blog=4322  backend=4323
HOST=127.0.0.1
PORT=4321

# ---- backend/ only ----
# Admin password hash (scrypt). Generate with:
#   node misc/scripts/gen-password-hash.mjs 'your-password'
# Format: scrypt:<saltHex>:<hashHex>
ADMIN_PASSWORD_HASH=

# Session signing secret. Use >=32 random bytes, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# production | development  (controls Secure cookies, error verbosity)
NODE_ENV=development
